# ══════════════════════════════════════════════════════════════
#  .env.example — Template de variables de entorno del curso
#
#  INSTRUCCIONES:
#    1. Copia este archivo: cp .env.example .env
#    2. Rellena con tus valores reales
#    3. NUNCA subas el .env al repositorio (está en .gitignore)
#    4. Este .env.example SÍ puede subirse (no tiene valores reales)
# ══════════════════════════════════════════════════════════════

# ── OpenAI (módulos 01, 02, 03-openai) ──────────────────────
OPENAI_API_KEY=sk-proj-REEMPLAZA_CON_TU_CLAVE

# ── LangSmith — trazabilidad de agentes (opcional) ───────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_REEMPLAZA_CON_TU_CLAVE
LANGCHAIN_PROJECT=cloud-ai-centric-course

# ── Google Cloud Platform (módulos 03-gcp, 04) ───────────────
PROJECT_ID=REEMPLAZA_CON_TU_PROJECT_ID
LOCATION=us-central1
GCP_API_KEY=REEMPLAZA_CON_TU_API_KEY

# ── Tavily — búsqueda web en agentes (opcional) ───────────────
TVLY_API_KEY=tvly-REEMPLAZA_CON_TU_CLAVE
