# ══════════════════════════════════════════════════════════════
#  modulo_03_gcp / src / .env.example
#
#  INSTRUCCIONES:
#    cp src/.env.example src/.env
#    → Rellena los valores y NUNCA subas el .env
# ══════════════════════════════════════════════════════════════

# ID de tu proyecto en Google Cloud Platform
# Lo encuentras en: https://console.cloud.google.com → selector de proyectos
PROJECT_ID=REEMPLAZA_CON_TU_PROJECT_ID

# Región de Vertex AI (no cambies esto)
LOCATION=us-central1

# API Key de GCP (opcional si usas Application Default Credentials)
# Solo necesaria si NO usas: gcloud auth application-default login
GCP_API_KEY=REEMPLAZA_SI_USAS_API_KEY
