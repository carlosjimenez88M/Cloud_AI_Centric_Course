#  INSTRUCCIONES:
#    cp src/.env.example src/.env
#    → Rellena los valores y NUNCA subas el .env
# ══════════════════════════════════════════════════════════════

# ID de tu proyecto en Google Cloud Platform
# Cómo obtenerlo: gcloud config get-value project
PROJECT_ID=REEMPLAZA_CON_TU_PROJECT_ID

# Región de Vertex AI (no cambies esto a menos que sepas lo que haces)
LOCATION=us-central1

# API Key de GCP (solo si usas API Key en lugar de ADC)
# Para cursos recomendamos ADC: gcloud auth application-default login
GCP_API_KEY=REEMPLAZA_SI_USAS_API_KEY
